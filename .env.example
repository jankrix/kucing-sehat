OPENAI_API_KEY=sk-your-api-key-here

# Supabase - get these from your Supabase project dashboard (Settings > API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Admin dashboard secret — set a strong random value: openssl rand -hex 32
ADMIN_SECRET=change-me-to-a-strong-secret

# Store lab images in Supabase Storage after extraction (default: false).
# Each image is 200KB–2MB. Free tier = 1GB. Enable only if you need to keep originals.
STORE_LAB_IMAGES=false
